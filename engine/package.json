{
  "name": "@privguard/engine",
  "version": "0.2.4",
  "description": "Zero-dependency PII detection and sanitization engine with local proxy for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "privguard": "dist/main-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "import": "./dist/proxy/index.js"
    }
  },
  "files": [
    "dist",
    "rules",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-gui-cjs.mjs",
    "build:skill": "node scripts/build-skill-cjs.mjs",
    "build:gui": "node scripts/build-gui-cjs.mjs",
    "sync:skill": "node scripts/build-skill-cjs.mjs --sync",
    "prepublishOnly": "tsc && node scripts/build-gui-cjs.mjs",
    "test": "node --import tsx --test src/**/*.test.ts",
    "check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrivGuardClaw/PrivGuardEngine.git"
  },
  "author": "PrivGuard Team",
  "bugs": {
    "url": "https://github.com/PrivGuardClaw/PrivGuardEngine/issues"
  },
  "homepage": "https://github.com/PrivGuardClaw/PrivGuardEngine#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "pii",
    "sanitize",
    "privacy",
    "redact",
    "proxy",
    "ai-agent",
    "claude",
    "llm",
    "sensitive-data"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
